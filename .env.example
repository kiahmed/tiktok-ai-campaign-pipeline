# =====================================================================
# Application
# =====================================================================
APP_NAME=tiktok-ad-automator
LOG_LEVEL=INFO
# Directory where generated videos are downloaded
VIDEO_STORAGE_DIR=generated_videos

# =====================================================================
# Database
# ---------------------------------------------------------------------
# SQLite (default, zero-config):
#   sqlite:///./app.db
# PostgreSQL (just change this line, no code changes):
#   postgresql+psycopg2://user:password@localhost:5432/tiktok_ads
# =====================================================================
DATABASE_URL=sqlite:///./app.db

# =====================================================================
# Provider selection — switching providers requires ONLY editing these.
# =====================================================================
# Options: gemini | openai | claude
SCRIPT_PROVIDER=gemini
# Options: heygen | kling | veo | pexo | creatify | arcads
VIDEO_PROVIDER=heygen
# Creative style (IGNORED when VIDEO_PROVIDER=heygen — HeyGen always renders a
# voiced avatar): product (image2video + voiceover, no lip-sync) |
#                 talking_head (text2video person + Kling lip-sync to the voice)
CREATIVE_MODE=product
# Ad platform: tiktok (the only supported platform)
AD_PLATFORM=tiktok
# Quality Review judge LLM. Empty => reuse SCRIPT_PROVIDER. (gemini|openai|claude)
QC_PROVIDER=
# Run the LLM QC judge on top of the deterministic rules (true|false)
QC_LLM_ENABLED=true

# =====================================================================
# Script provider credentials
# =====================================================================
GEMINI_API_KEY=
# Current model. (gemini-2.0-flash is retired.) Alternatives: gemini-flash-latest, gemini-2.5-flash
GEMINI_MODEL=gemini-3.5-flash

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# =====================================================================
# Video provider credentials
# =====================================================================
# Veo 3.1 via the Gemini API (default). Leave VEO_API_KEY blank to reuse GEMINI_API_KEY.
VEO_API_KEY=
VEO_MODEL=veo-3.1-generate-preview
VEO_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# 9:16 @ 1080p => 1080x1920 (TikTok/Reels). Options: 720p | 1080p
VEO_RESOLUTION=1080p

PEXO_API_KEY=
PEXO_BASE_URL=https://api.pexo.ai

CREATIFY_API_KEY=
ARCADS_API_KEY=

# Kling AI (default). Official API uses JWT (access + secret key):
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
# ...or a gateway (PiAPI/fal/...) bearer key instead (leave access/secret blank):
KLING_API_KEY=
KLING_BASE_URL=https://api-singapore.klingai.com
KLING_MODEL=kling-v1
KLING_DURATION=10
KLING_MODE=std
# Pad/fit the product image to 9:16 before image2video (output ratio follows the image)
KLING_PREPARE_IMAGE=true

# HeyGen v3 (https://developers.heygen.com/image-to-video). Renders a finished,
# voiced video — no ElevenLabs/ffmpeg needed. By DEFAULT HeyGen AUTO-PICKS an
# avatar + voice from its own libraries (leave AVATAR_ID/VOICE_ID blank); it
# fetches /v2/avatars and /v2/voices and chooses for you.
HEYGEN_API_KEY=
HEYGEN_BASE_URL=https://api.heygen.com
# Leave blank to auto-select. Set to pin a specific HeyGen avatar / voice.
HEYGEN_AVATAR_ID=
HEYGEN_VOICE_ID=
# Gender to cast is taken from profiles.json creative.narrator automatically
# (e.g. "male"). This is only an override for when no narrator is set; blank is
# fine. Empty narrator AND empty here => the LLM infers gender from the script.
HEYGEN_PREFER_GENDER=
# Avatar casting: true => LLM picks the best-fitting spokesperson (tends to
# repeat the SAME person). false => pick RANDOMLY among the top-N for variety.
HEYGEN_SMART_AVATAR=false
HEYGEN_MAX_AVATAR_CANDIDATES=50
# Randomize the presenter among this many top male candidates (variety per video)
HEYGEN_AVATAR_POOL=8
# Optional: animate a photo (image-to-video) INSTEAD of an avatar. Needs a face.
HEYGEN_IMAGE_URL=
# Blank => HeyGen defaults to Avatar IV (standard avatars). Set avatar_v ONLY
# for Avatar-V-eligible avatars, else HeyGen rejects with invalid_parameter.
HEYGEN_ENGINE=
HEYGEN_RESOLUTION=1080p
HEYGEN_ASPECT_RATIO=9:16
HEYGEN_SPEED=1.0
HEYGEN_REMOVE_BACKGROUND=false
# Avatar background: none | script (generate a scene image from the script and
# place the presenter in front of it) | image (HEYGEN_BACKGROUND=url) | color (#hex)
HEYGEN_BACKGROUND_MODE=none
HEYGEN_BACKGROUND=
# Image generation (used only for HEYGEN_BACKGROUND_MODE=script). Needs Imagen
# access on your Google key. gemini | none
IMAGE_PROVIDER=gemini
IMAGEN_MODEL=imagen-4.0-generate-001
# On HTTP 429 (quota/rate limit) wait this long and retry. Raise if your limit
# is per-minute; if quota is hard-exhausted, raise it on Google Cloud instead.
IMAGEN_MAX_RETRIES_429=1
IMAGEN_RETRY_WAIT_SECONDS=20

# Product cutaway: briefly cut to a full-screen product shot while the narration
# continues (presenter leaves the screen). Post-step on the rendered video (ffmpeg).
PRODUCT_CUTAWAY_ENABLED=false
PRODUCT_CUTAWAY_SECONDS=2.5
# Fixed placement (fraction through the video) used when the script doesn't name the product
PRODUCT_CUTAWAY_AT=0.4
# zoom (gentle Ken-Burns) | still
PRODUCT_CUTAWAY_STYLE=zoom
# Place the cutaway at the moment the script mentions the product (approx)
PRODUCT_CUTAWAY_SYNC_TO_MENTION=true

# Story mode: multi-scene b-roll (Gemini beats+scenes) cut under the narration —
# a story, not a talking head. Adds ~1 LLM + several Imagen calls per video.
STORY_MODE_ENABLED=false
STORY_BEATS=4
STORY_HOOK_ON_AVATAR=true

# Hook card: a bold full-screen text "pattern interrupt" before the avatar.
# Style (bg/text colour) rotates randomly per video. Adds ~1.5s to the front.
HOOK_CARD_ENABLED=false
HOOK_CARD_SECONDS=1.5
HOOK_CARD_FONT_SIZE=96
HOOK_CARD_MAX_WORDS=10
HOOK_CARD_UPPERCASE=true

# Background music: Jamendo search -> random track -> ffmpeg mix under the voice.
# Free client_id from https://devportal.jamendo.com/. NOTE: Jamendo tracks are
# Creative Commons; with MUSIC_COMMERCIAL_ONLY=true only by/by-sa/cc0 tracks are
# used (safe for ads). The query "advertisement background" is mostly NC there —
# use e.g. "corporate background" for commercial-licensed tracks.
MUSIC_ENABLED=false
MUSIC_PROVIDER=jamendo
JAMENDO_CLIENT_ID=
MUSIC_QUERY=advertisement background
MUSIC_LIMIT=100
MUSIC_VOLUME=0.18
MUSIC_COMMERCIAL_ONLY=true

# Captions: burn subtitles from the script onto the video (ffmpeg post-step).
# Timing is approximate (cues distributed across the duration; no word-sync).
CAPTIONS_ENABLED=false
CAPTION_WORDS_PER_CUE=4
# Font size in REAL pixels on the 1080x1920 frame (small = ~40, large = ~70)
CAPTION_FONT_SIZE=44
# Distance from the bottom in pixels
CAPTION_MARGIN_V=180

# =====================================================================
# Voiceover (TTS) + merge — Kling has no voice, so ElevenLabs narrates the
# script and ffmpeg merges it onto the video. Needs ffmpeg installed.
# =====================================================================
VOICE_ENABLED=true
VOICE_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_multilingual_v2
ELEVENLABS_BASE_URL=https://api.elevenlabs.io
FFMPEG_PATH=ffmpeg

# =====================================================================
# Ad platform credentials & existing-resource IDs
# The system NEVER creates campaigns or ad groups — these must exist.
# =====================================================================
TIKTOK_ACCESS_TOKEN=
TIKTOK_ADVERTISER_ID=
TIKTOK_CAMPAIGN_ID=
TIKTOK_ADGROUP_ID=
TIKTOK_BASE_URL=https://business-api.tiktok.com/open_api/v1.3
# Token auto-refresh (access token expires). Fill these to enable refresh;
# leave blank for a long-lived/static token. The rotated token is persisted to
# TIKTOK_TOKEN_STORE (gitignored).
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=
TIKTOK_REFRESH_TOKEN=
# Current token expiry as unix epoch seconds (0 => refresh on first use)
TIKTOK_TOKEN_EXPIRES_AT=0
TIKTOK_TOKEN_STORE=config/tiktok_token.json

# =====================================================================
# Standalone cron scripts (scripts/cron_generate.py, cron_clone_campaign.py)
# =====================================================================
# Base URL of the running API the cron scripts call.
API_BASE_URL=http://localhost:8000
# Video-generation cron cadence + which products to generate for.
GENERATE_INTERVAL_HOURS=24
GENERATE_PRODUCT_IDS=

# =====================================================================
# Campaign cloning (done only by scripts/cron_clone_campaign.py, never in-app)
# =====================================================================
CAMPAIGN_CLONE_INTERVAL_DAYS=30
CAMPAIGN_NAME_PREFIX=Auto Campaign

# =====================================================================
# Monitoring & automatic pause rules
# =====================================================================
# How often performance metrics are pulled (cron-style hour interval)
MONITOR_INTERVAL_HOURS=1

# Rule 1: pause if spend exceeds this AND conversions == 0
PAUSE_MAX_SPEND_NO_CONV=50.0
# Rule 2: pause if CTR (as a fraction, 0.005 == 0.5%) falls below this
PAUSE_MIN_CTR=0.005
# Rule 3: pause if ROAS falls below this
PAUSE_MIN_ROAS=1.0
# Ignore young ads with negligible spend to avoid premature pausing
PAUSE_MIN_SPEND_TO_EVALUATE=5.0

# =====================================================================
# Agent pipeline
# =====================================================================
# Brand / audience / creative-rules profiles (QC thresholds + brand voice)
PROFILES_PATH=config/profiles.json
# Script->video->QC attempts before a job is DISCARDED
JOB_MAX_ATTEMPTS=3

# ---- Video output specs (enforced by Quality Review) ----
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_FPS=30
VIDEO_FORMATS=mp4,mov
# 72 MB = strict Android limit (safe for both platforms); iOS allows up to 287
VIDEO_MAX_FILE_MB=72
# Deep-verify real resolution/fps via ffprobe (needs ffmpeg). Off => size+format only.
VIDEO_CHECK_MEDIA=false

# Script de-duplication: lexical (offline, zero-dep) | embedding (local model, semantic, no API)
NOVELTY_METHOD=lexical
# Similarity threshold to treat a script as a duplicate; 0 => method default (lexical 0.5, embedding 0.85)
NOVELTY_THRESHOLD=0
# Local embedding model used when NOVELTY_METHOD=embedding (runs offline after first download)
# Requires: pip install -r requirements-embeddings.txt
EMBEDDING_MODEL=all-MiniLM-L6-v2
